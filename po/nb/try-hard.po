#: src/Try-Hard/try-hard:45
msgid "Usage:"
msgstr "Bruk:"

#: src/Try-Hard/try-hard:81 src/Try-Hard/try-hard:91 src/Try-Hard/try-hard:101
#: src/Try-Hard/try-hard:111 src/Try-Hard/try-hard:156
#, sh-format
msgid "ERROR: Invalid delay value ${delayValue}!"
msgstr "FEIL: Ugyldig forsinkelse ${delayValue}!"

#: src/Try-Hard/try-hard:150
#, sh-format
msgid "ERROR: Invalid maximum trials ${MAX_TRIALS}!"
msgstr "FEIL: Ugyldig maksimalt antall forsøk ${MAX_TRIALS}!"

#: src/Try-Hard/try-hard:196
#, sh-format
msgid "Tried ${MAX_TRIALS} times -> giving up now!"
msgstr "Prøvde ${MAX_TRIALS} ganger -> gir opp nå!"

#: src/Try-Hard/try-hard:227
#, sh-format
msgid "Trial ${trial}/${MAX_TRIALS} failed -> waiting random time from [${minDelay}, ${maxDelay}] s ..."
msgstr "Forsøk ${trial}/${MAX_TRIALS} feilet -> venter en tilfeldig tidsperiode mellom [${minDelay}, ${maxDelay}] s før nytt forsøk ..."

#: src/Try-Hard/try-hard:234
#, sh-format
msgid "Trial ${trial}/${MAX_TRIALS} failed -> waiting for ${maxDelay} s ..."
msgstr "Forsøk ${trial}/${MAX_TRIALS} feilet -> venter ${maxDelay} s før nytt forsøk ..."
