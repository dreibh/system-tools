#: src/Reset-Machine-ID/Reset-Machine-ID:183
msgid "Usage:"
msgstr "Aufruf:"

#: src/Reset-Machine-ID/Reset-Machine-ID:249
#, sh-format
msgid "ERROR: Invalid hostname ${hostname}!"
msgstr "FEHLER: Ungültiger Hostname ${hostname}!"

#: src/Reset-Machine-ID/Reset-Machine-ID:300
msgid "ERROR: Reset-Machine-ID requires superuser permissions!"
msgstr "FEHLER: Reset-Machine-ID erfordert Superuser-Berechtigungen!"

#: src/Reset-Machine-ID/Reset-Machine-ID:368
msgid "Update hostname?"
msgstr "Hostname aktualisieren?"

#: src/Reset-Machine-ID/Reset-Machine-ID:392
#, sh-format
msgid "The current machine ID is ${machineID}. Reset it?"
msgstr "Die aktuelle Maschinen-ID ist ${machineID}. Zurücksetzen?"

#: src/Reset-Machine-ID/Reset-Machine-ID:411
#, sh-format
msgid "The new machine ID is ${machineID}."
msgstr "Die neue Maschinen-ID ist ${machineID}."

#: src/Reset-Machine-ID/Reset-Machine-ID:442
msgid "Install Zabbix agent?"
msgstr "Zabbix-Agent installieren?"

#: src/Reset-Machine-ID/Reset-Machine-ID:474
#, sh-format
msgid "Apply suggested Zabbix Agent changes in ${zabbixConfig}?"
msgstr "Vorgeschlagene Änderungen für Zabbix-Agent in ${zabbixConfig} durchführen?"

#: src/Reset-Machine-ID/Reset-Machine-ID:487
#: src/Reset-Machine-ID/Reset-Machine-ID:560
#: src/Reset-Machine-ID/Reset-Machine-ID:659
#: src/Reset-Machine-ID/Reset-Machine-ID:714
msgid "Skipped!"
msgstr "Übersprungen!"

#: src/Reset-Machine-ID/Reset-Machine-ID:523
msgid "Checking SSH configuration ..."
msgstr "Untersuche SSH-Konfiguration ..."

#: src/Reset-Machine-ID/Reset-Machine-ID:549
msgid "Suggested ssh_config changes:"
msgstr "Vorgeschlagene Änderungen in ssh_config:"

#: src/Reset-Machine-ID/Reset-Machine-ID:553
msgid "Apply suggested ssh_config changes?"
msgstr "Vorgeschlagene Änderungen in ssh_config durchführen?"

#: src/Reset-Machine-ID/Reset-Machine-ID:627
msgid "Suggested removal of sshd_config.d/50-cloud-init.conf:"
msgstr "Vorgeschlagene Entfernung von sshd_config.d/50-cloud-init.conf:"

#: src/Reset-Machine-ID/Reset-Machine-ID:635
msgid "Suggested sshd_config changes:"
msgstr "Vorgeschlagene Änderungen in sshd_config:"

#: src/Reset-Machine-ID/Reset-Machine-ID:642
msgid "Apply suggested sshd_config changes?"
msgstr "Vorgeschlagene Änderungen in sshd_config durchführen?"

#: src/Reset-Machine-ID/Reset-Machine-ID:650
#: src/Reset-Machine-ID/Reset-Machine-ID:707
msgid "Trying to restart SSH daemon ..."
msgstr "Versuche Neustart des SSH-Daemons ..."

#: src/Reset-Machine-ID/Reset-Machine-ID:673
msgid "Remove existing SSH host keys and generate new ones?"
msgstr "Existierende SSH-Schlüssel entfernen und neue Schlüssel erstellen?"

#: src/Reset-Machine-ID/Reset-Machine-ID:679
#, sh-format
msgid "Making backup of current keys in ${backupDirectory} ..."
msgstr "Erstelle Backup der gegenwärtigen Schlüssel in ${backupDirectory} ..."

#: src/Reset-Machine-ID/Reset-Machine-ID:697
msgid "Generating new ED25519 key ..."
msgstr "Erstelle neuen ED25519-Schlüssel ..."

#: src/Reset-Machine-ID/Reset-Machine-ID:699
msgid "Generating new ECDSA key ..."
msgstr "Erstelle neuen ECDSA-Schlüssel ..."

#: src/Reset-Machine-ID/Reset-Machine-ID:701
msgid "Generating new RSA key; this may take some time ..."
msgstr "Erstelle neuen RSA-Schlüssel; dies kann einen Moment dauern ..."

#: src/Reset-Machine-ID/Reset-Machine-ID:704
msgid "Done!"
msgstr "Erledigt!"
