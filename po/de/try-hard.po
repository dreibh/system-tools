#: src/Try-Hard/try-hard:45
msgid "Usage:"
msgstr "Aufruf:"

#: src/Try-Hard/try-hard:109 src/Try-Hard/try-hard:119
#: src/Try-Hard/try-hard:129 src/Try-Hard/try-hard:139
#: src/Try-Hard/try-hard:184
#, sh-format
msgid "ERROR: Invalid delay value ${delayValue}!"
msgstr "FEHLER: Ungültiger Verzögerungswert ${delayValue}!"

#: src/Try-Hard/try-hard:178
#, sh-format
msgid "ERROR: Invalid maximum trials ${MAX_TRIALS}!"
msgstr "FEHLER: Ungültige maximale Anzahl an Versuchen ${MAX_TRIALS}!"

#: src/Try-Hard/try-hard:189
msgid "ERROR: Cannot find random-sleep in the search path!"
msgstr "FEHLER: random-sleep konnte im Suchpfad nicht gefunden werden!"

#: src/Try-Hard/try-hard:227
#, sh-format
msgid "Tried ${MAX_TRIALS} times -> giving up now!"
msgstr "${MAX_TRIALS} Mal versucht -> gebe jetzt auf!"

#: src/Try-Hard/try-hard:258
#, sh-format
msgid "Trial ${trial}/${MAX_TRIALS} failed (exit code ${exitStatus}) -> waiting random time from [${minDelay}, ${maxDelay}] s ..."
msgstr "Versuch ${trial}/${MAX_TRIALS} fehlgeschlagen (Rückgabewert ${exitStatus}) -> warte zufällige Zeitspanne aus [${minDelay}, ${maxDelay}] s vor einem erneuten Versuch ..."

#: src/Try-Hard/try-hard:265
#, sh-format
msgid "Trial ${trial}/${MAX_TRIALS} failed -> waiting for ${maxDelay} s ..."
msgstr "Versuch ${trial}/${MAX_TRIALS} fehlgeschlagen -> warte ${maxDelay} s vor einem erneuten Versuch ..."
