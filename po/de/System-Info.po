#: src/System-Info/System-Info:112
msgctxt ""
"The error message to print when the get-system-info executable has not been "
"found"
msgid "ERROR: get-system-info not found in search path!"
msgstr "FEHLER: get-system-info nicht im Suchpfad gefunden!"

#: src/System-Info/System-Info:149
msgctxt "The text to print when ID, release, or codename is unknown"
msgid "Unknown"
msgstr "Unbekannt"

#: src/System-Info/System-Info:189
msgctxt "The label of the field containing the hostname of the computer"
msgid "Host:"
msgstr "Rechner:"

#: src/System-Info/System-Info:195
msgctxt "The label of the field containing the uptime of the computer"
msgid "Uptime:"
msgstr "Betriebszeit:"

#: src/System-Info/System-Info:196
msgctxt ""
"The printf format string to print the uptime of the computer, split into the "
"components days, hours, minutes, seconds. Each of the components is provided "
"as string. Example: '1 day, 10 hours, 25 minutes, and 44 seconds'."
msgid "%s, %s, %s, and %s"
msgstr "%s, %s, %s und %s"

#: src/System-Info/System-Info:197
msgctxt ""
"The printf format string to print the number of days for the uptime of the "
"computer, e.g. '1 day', or '42 days'"
msgid "%'d day"
msgid_plural "%'d days"
msgstr[0] "%'d Tag"
msgstr[1] "%'d Tage"

#: src/System-Info/System-Info:198
msgctxt ""
"The printf format string to print the number of hours for the uptime of the "
"computer, e.g. '1 hour', or '12 hours'"
msgid "%'d hour"
msgid_plural "%'d hours"
msgstr[0] "%'d Stunde"
msgstr[1] "%'d Stunden"

#: src/System-Info/System-Info:199
msgctxt ""
"The printf format string to print the number of minutes for the uptime of "
"the computer, e.g. '1 minute', or '10 minutes'"
msgid "%'d minute"
msgid_plural "%'d minutes"
msgstr[0] "%'d Minute"
msgstr[1] "%'d Minuten"

#: src/System-Info/System-Info:200
msgctxt ""
"The printf format string to print the number of seconds for the uptime of "
"the computer, e.g. '1 second', or '33 seconds'"
msgid "%'d second"
msgid_plural "%'d seconds"
msgstr[0] "%'d Sekunde"
msgstr[1] "%'d Sekunden"

#: src/System-Info/System-Info:205
msgctxt ""
"The label of the field containing the operating system of the computer"
msgid "Operating System:"
msgstr "Betriebssystem:"

#: src/System-Info/System-Info:206
#, sh-format
msgctxt ""
"Combination of operating system information (in variable 'os_label') and "
"kernel release information (in variable 'system_release'), e.g. 'Ubuntu "
"24.04 with kernel 6.17.0-20-generic'."
msgid "${os_label} with kernel ${system_release}"
msgstr "${os_label} mit Kernel ${system_release}"

#: src/System-Info/System-Info:210
msgctxt ""
"The printf format string to print the number of processes running on the "
"computer, e.g. '123 processes'"
msgid "%'d processes"
msgstr "%'d Prozesse"

#: src/System-Info/System-Info:212
msgctxt ""
"The printf format string to print the users of the computer, e.g. '1 user', "
"or '3 users'"
msgid "%'d user"
msgid_plural "%'d users"
msgstr[0] "%'d Benutzer"
msgstr[1] "%'d Benutzer"

#: src/System-Info/System-Info:214
msgctxt ""
"The label of the field containing information about the processor (i.e. CPU) "
"of the computer"
msgid "Processor:"
msgstr "Prozessor:"

#: src/System-Info/System-Info:216
#, sh-format
msgctxt ""
"Combination of number of CPU cores (in variable 'system_cores') and details "
"of the CPU of the computer (in variable 'system_machine') with details about "
"processes (in variable 'processesString') and details about users (in "
"variable 'usersString'), e.g. '8 × x86_64; 435 processes; 1 user'"
msgid "${system_cores} × ${system_machine}; ${processesString}; ${usersString}"
msgstr ""
"${system_cores} × ${system_machine}; ${processesString}; ${usersString}"

#: src/System-Info/System-Info:222
msgctxt ""
"The label of the field containing information about the system load "
"percentages of the computer in the last 1 minute/5 minutes/15 minutes"
msgid "Load (1/5/15 min):"
msgstr "Last (1/5/15 Min.):"

#: src/System-Info/System-Info:223
msgctxt ""
"The printf format string to print the load percentage of the computer over 1 "
"minute (in variable 'system_load_avg1min') / 5 minutes (in variable "
"'system_load_avg5min') / 15 minutes (in variable 'system_load_avg15min'), e."
"g. '52.1% / 20.3% / 11.1%'"
msgid "%1.1f %% / %1.1f %% / %1.1f %%"
msgstr "%1.1f %% / %1.1f %% / %1.1f %%"

#: src/System-Info/System-Info:260
msgctxt "Battery status of the computer when the battery is unknown"
msgid "unknown"
msgstr "unbekannt"

#: src/System-Info/System-Info:264
msgctxt "Battery status of the computer when the battery is not charging"
msgid "not charging"
msgstr "lädt nicht"

#: src/System-Info/System-Info:267
msgctxt "Battery status of the computer when the battery is charging"
msgid "charging"
msgstr "lädt"

#: src/System-Info/System-Info:270
msgctxt "Battery status of the computer when the battery is fully charged"
msgid "full"
msgstr "vollständig aufgeladen"

#: src/System-Info/System-Info:274
msgctxt "Battery status of the computer when the battery is discharging"
msgid "discharging"
msgstr "entlädt"

#: src/System-Info/System-Info:282
#, sh-format
msgctxt ""
"Combination of battery number (in variable 'batteryNumber'), battery status "
"(in variable 'batteryStatus'), and battery capacity in percent (in variable "
"'batteryCapacity'), e.g. '#1 charging, 87 %'"
msgid "#${batteryNumber} ${batteryStatus}, ${batteryCapacity} %"
msgstr "${batteryNumber}. ${batteryStatus}, ${batteryCapacity} %"

#: src/System-Info/System-Info:286
msgctxt ""
"The label of the field containing information about the battery of the "
"computer"
msgid "Battery:"
msgstr "Batterie:"

#: src/System-Info/System-Info:293
msgctxt ""
"The label of the field containing information about the used memory (RAM) of "
"the computer"
msgid "Used Memory:"
msgstr "Belegtes RAM:"

#: src/System-Info/System-Info:294
msgctxt ""
"The printf format string to print the details about the used memory (RAM) in "
"MiB, e.g. '9969 MiB of  31941 MiB ( 21972 MiB available:  68.8 %)'"
msgid "%'6.0f MiB of %'6.0f MiB (%'6.0f MiB available: %'5.1f %%)"
msgstr "%'6.0f MiB von %'6.0f MiB (%'6.0f MiB verfügbar: %'5.1f %%)"

#: src/System-Info/System-Info:303 src/System-Info/System-Info:312
msgctxt ""
"The label of the field containing information about the used swap space of "
"the computer"
msgid "Used Swap:"
msgstr "Belegter Swap:"

#: src/System-Info/System-Info:304
msgctxt ""
"The printf format string to print the details about the used swap space in "
"MiB, e.g. '1317 MiB of   8191 MiB (  6874 MiB available:  83.9 %)'"
msgid "%'6.0f MiB of %'6.0f MiB (%'6.0f MiB available: %'5.1f %%)"
msgstr "%'6.0f MiB von %'6.0f MiB (%'6.0f MiB verfügbar: %'5.1f %%)"

#: src/System-Info/System-Info:313
msgctxt "Text to print when the computer has no swap space"
msgid "no swap available!"
msgstr "Swap nicht vorhanden!"

#: src/System-Info/System-Info:343
msgctxt ""
"The printf format string to print the usage percentage of storage at a mount "
"point, e.g.'88 % on /home', or '92 % on /tmp'"
msgid "%1.0f %% on %s"
msgstr "%1.0f %% auf %s"

#: src/System-Info/System-Info:349
msgctxt ""
"The label of the field containing information about the used disk space of "
"the computer"
msgid "Used Diskspace:"
msgstr "Speicherplatz:"

#: src/System-Info/System-Info:358
msgctxt ""
"The label of the field containing information about the network interfaces "
"of the computer"
msgid "Network:"
msgstr "Netzwerk:"

#: src/System-Info/System-Info:388
msgctxt ""
"Text to print when the network interface of the computer has no IPv4 "
"addresses"
msgid "(No IPv4)"
msgstr "(Kein IPv4)"

#: src/System-Info/System-Info:426
msgctxt ""
"The label of the field containing information about the SSH keys of the "
"computer"
msgid "SSH Keys:"
msgstr "SSH-Schlüssel:"

#: src/System-Info/System-Info:433
#, sh-format
msgctxt ""
"Combination of SSH key number (in variable 'keyNumber') and SSH key "
"information (in variable 'keyInfo'), e.g. '#3 SHA256:mcAJ7V/"
"RbRzk89lkMx1rnA1qgiRWkMttHEiKvWJOBqU (RSA 16384)')"
msgid "#${keyNumber} ${keyInfo}"
msgstr "${keyNumber}. ${keyInfo}"

#: src/System-Info/System-Info:445
msgctxt ""
"Text to prepend the usage syntax when calling the program without "
"parameters, e.g. 'Usage: program arg1 arg2 [options ...]'"
msgid "Usage:"
msgstr "Aufruf:"

#: src/System-Info/System-Info:488
#, sh-format
msgctxt ""
"Title text for system information with date/time (in variable 'now'), e.g. "
"'System information on Sun Apr 19 17:04:33 CEST 2026'"
msgid "System information on ${now}"
msgstr "Systeminformation am ${now}"

#: src/System-Info/system-info.d/01-example:58
#: src/System-Info/system-info.d/10-company-logo-example:73
msgctxt "Information in which directory the banner can be changed"
msgid "You can change this banner in /etc/system-info.d!"
msgstr "Dieses Banner kann in /etc/system-info.d geändert werden!"

#: src/System-Info/system-info.d/09-hostname-example:50
msgctxt "Welcome title message to print when the user logged into the system"
msgid "Welcome on the System"
msgstr "Willkommen auf dem System"

#: src/System-Info/system-info.d/10-company-logo-example:53
msgctxt ""
"Welcome title to print before the company logo text, e.g. 'Welcome to "
"SimulaMet'"
msgid "Welcome to"
msgstr "Willkommen bei"
