# Bash options:
set -eux


INPUT1="examples/Bergen.jpeg"
INPUT2="examples/Portobello.jpeg"
INPUT3="Background.png"


# ====== Use FractGen to generate the example image =========================
# Requires: clifractgen
if [ ! -e "${INPUT2}"  ] ; then
   if [ -e "/usr/share/fractgen/examples/alpha07.fsf" ] ; then
      clifractgen  /usr/share/fractgen/examples/alpha07.fsf "${INPUT3}" -W 1920 -H 1080 -M 2048
   elif [ -e "/usr/local/share/fractgen/examples/alpha07.fsf" ] ; then
      clifractgen  /usr/local/share/fractgen/examples/alpha07.fsf "${INPUT3}" -W 1920 -H 1080 -M 2048
   else
      echo >&2 "ERROR: Input FSF file not found!"
      exit 1
   fi
fi


# ====== Resize-with-Cropping ===============================================
./Resize-with-Cropping "${INPUT1}" Image1.png -A 16:9 -W 1920
./Resize-with-Cropping "${INPUT2}" Image2.png --aspect 16:9 --width 1920


# ====== Make-Caption =======================================================
./Make-Caption Caption1.png 1024 42 \
   "Caption Text $(LC_ALL=C.UTF-8 date)" \
   --font-name "Noto Sans Bold" \
   --font-size 70 \
   --foreground "#02266b" --background "#ffd7cc" --transparency 50
./Make-Caption Caption2.png 1920 64 \
   "This is yet another test on $(LC_ALL=C.UTF-8 date)!" \
   -F "Lobster Two Bold Italic" \
   -S 70 \
   -f "#02266b" -b "#ffd700" -t 26


# ====== Make-GlossyText ====================================================
./Make-GlossyText NorNet1.png "NorNet Testbed" 128

./Make-GlossyText NorNet2.png "NorNet Testbed" 128 --bordersize 5 \
   --colorscheme "Brushed Aluminium" --font "Noto Sans Bold"

# Requires: fonts-lobster
./Make-GlossyText NorNet3.png "NorNet Testbed" 128 --bordersize 5 \
   --colorscheme "Golden" --font "Lobster Two Bold Italic" || true


# ====== Make-Mosaic ========================================================
for tileType in triangles squares hexagons octagons ; do
   for tileSurface in smooth rough ; do
      for tileSize in 12 24 ; do
         ./Make-Mosaic Image1.png "Mosaic1-T${tileType}-S${tileSize}-F${tileSurface}.png" \
            --tile-type "${tileType}" \
            --tile-size "${tileSize}" \
            --tile-height 4.0 \
            --tile-neatness 0.25 \
            --tile-surface "${tileSurface}" \
            --tile-spacing 4.0 \
            --tile-allow-split on \
            --color-variation 0.15 \
            --color-averaging on \
            --light-direction 275.5
         ./Make-Mosaic Image2.png "Mosaic2-T${tileType}-S${tileSize}-F${tileSurface}.png" \
            -T "${tileType}" \
            -S "${tileSize}" \
            -H 5.0 \
            -N 0.25 \
            -F "${tileSurface}" \
            -X 5.0 \
            -I off \
            -C 0.25 \
            -G off \
            -L 75.5
      done
   done
done

# ====== Make-OldPhoto ======================================================
for defocus in on off ; do
   for borderSize in 10 20 ; do
      for sepia in on off ; do
         ./Make-OldPhoto Image1.png "OldPhoto1-D${defocus}-B${borderSize}-S${sepia}-Mon.png" \
            --defocus "${defocus}" \
            --border-size "${borderSize}" \
            --sepia "${sepia}" \
            --mottle on
         ./Make-OldPhoto Image2.png "OldPhoto2-D${defocus}-B${borderSize}-S${sepia}-Moff.png" \
            -D "${defocus}" \
            -B "${borderSize}" \
            -S "${sepia}" \
            -M off
      done
   done
done

# ====== Make-Clothify ======================================================
for blurX in 3 6 ; do
   blurY="${blurX}"
   for azimut in 90.0 135.0 180.0 ; do
      for elevation in 10.0 45.0 80.0 ; do
         for depth in 4 ; do
            ./Make-Clothify Image1.png "Cloth1-X${blurX}-Y${blurY}-A${azimut}$-E${elevation}-D4.png" \
               --blur-x ${blurX} \
               --blur-y ${blurY} \
               --azimut "${azimut}" \
               --elevation "${elevation}" \
               --depth 4
            ./Make-Clothify Image2.png "Cloth2-X${blurX}-Y${blurY}-A${azimut}$-E${elevation}-D8.png" \
               -X ${blurX} \
               -Y ${blurY} \
               -A "${azimut}" \
               -E "${elevation}" \
               -D 8
         done
      done
   done
done

# ====== Make-Oilify ========================================================
for maskSize 4 8 16 ; do
   ./Make-Oilify Image1.png "Oilify1-S${maskSize}-Ion.png" \
      --mask-size "${maskSize}" \
      --intensity-mode on
   ./Make-Oilify Image2.png "Oilify2-S${maskSize}-Ioff.png" \
      -S "${maskSize}" \
      -I off
done

# ====== Make-BumpMap =======================================================
./Make-BumpMap Image3.png Background1.png
./Make-Mosaic Background1.png Background2.png \
   -T hexagons -S 18 -H 4 -X 4 -F smooth -N 0.5
