# Bash options:
set -euo pipefail

# gettext options:
export TEXTDOMAIN="try-hard"
# export TEXTDOMAINDIR="${PWD}/locale"   # Default: "/usr/share/locale"

# shellcheck disable=SC1091
. gettext.sh


# ###### Usage ##############################################################
usage () {
   local exitCode="$1"
   echo >&2 "$(gettext "Usage:") $0 max_trials max_delay [-m|--min-delay min_delay] [-A|--additive-increase delay_increment] [-M|--multiplicative-increase delay_factor] [-T|--truncate-delay truncated_max_delay] [-D|--deterministic] [-q|--quiet] [-w|--verbose] [-h|--help] [-v|--version] -- command ..."
   exit "${exitCode}"
}


# ###### Version ############################################################
version () {
   echo "try-hard @BUILD_MAJOR@.@BUILD_MINOR@.@BUILD_PATCH@"
   exit 0
}



# ###### Main program #######################################################

# ====== Handle arguments ===================================================
if (( BASH_VERSINFO[0] < 4 )) || (( (BASH_VERSINFO[0] == 4) && (BASH_VERSINFO[1] < 4) )) ; then
   echo "ERROR: Bash 4.4 or higher is required, but Bash ${BASH_VERSINFO[0]}.${BASH_VERSINFO[1]} is installed!"
   exit 1
fi
GETOPT="$(PATH="/usr/local/bin:${PATH}" command -v getopt)"
if "${GETOPT}" -T >/dev/null 2>&1 || [[ $? -ne 4 ]]; then
   echo >&2 "ERROR: Enhanced/GNU getopt is required!"
   exit 1
fi
options="$(${GETOPT} -o m:A:M:T:Dqwhv --long min-delay:,additive-increase:,multiplicative-increase:,truncate-delay:,deterministic,quiet,verbose,help,version -a -- "$@")"
# shellcheck disable=SC2181
if [[ $? -ne 0 ]]; then
   usage 1
fi
eval set -- "${options}"

VERBOSE=0
MIN_DELAY="0.0"
ADDITIVE_INCREASE="0.0"
MULTIPLICATIVE_INCREASE="1.0"
TRUNCATE_DELAY="31536000.0"   # 1 year
DETERMINISTIC=0
while [ $# -gt 0 ] ; do
   case "$1" in
      -m | --min-delay)
         delayValue="$2"
         shift
         if [[ ! "${delayValue}" =~ ^([0-9]+|[0-9]*\.[0-9]+|[0-9]+\.[0-9]*)$ ]] ; then
            eval_gettext >&2 "ERROR: Invalid delay value \${delayValue}!"
            echo >&2
            exit 1
         fi
         MIN_DELAY="${delayValue}"
         ;;
      -A | --additive-increase)
         delayValue="$2"
         shift
         if [[ ! "${delayValue}" =~ ^([0-9]+|[0-9]*\.[0-9]+|[0-9]+\.[0-9]*)$ ]] ; then
            eval_gettext >&2 "ERROR: Invalid delay value \${delayValue}!"
            echo >&2
            exit 1
         fi
         ADDITIVE_INCREASE="${delayValue}"
         ;;
      -M | --multiplicative-increase)
         delayValue="$2"
         shift
         if [[ ! "${delayValue}" =~ ^([0-9]+|[0-9]*\.[0-9]+|[0-9]+\.[0-9]*)$ ]] ; then
            eval_gettext >&2 "ERROR: Invalid delay value \${delayValue}!"
            echo >&2
            exit 1
         fi
         MULTIPLICATIVE_INCREASE="${delayValue}"
         ;;
      -T | --truncate-delay)
         delayValue="$2"
         shift
         if [[ ! "${delayValue}" =~ ^([0-9]+|[0-9]*\.[0-9]+|[0-9]+\.[0-9]*)$ ]] ; then
            eval_gettext >&2 "ERROR: Invalid delay value \${delayValue}!"
            echo >&2
            exit 1
         fi
         TRUNCATE_DELAY="${delayValue}"
         ;;
      -D | --deterministic)
         DETERMINISTIC=1
         ;;
      -q | --quiet)
         VERBOSE=0
         ;;
      -w | --verbose)
         VERBOSE=1
         ;;
      -h | --help)
         usage 0
         ;;
      -v | --version)
         version
         ;;
      --)
         shift
         break
         ;;
      *)
         # This should not happen: wrong getopt parameters, or missing case?
         echo >&2 "INTERNAL ERROR: Unhandled option $1!"
         exit 1
         ;;
  esac
  shift
done
if [ $# -lt 3 ] ; then
   usage 1
fi

MAX_TRIALS="$1"
if [[ ! "${MAX_TRIALS}" =~ ^[0-9]*$ ]] || [ "${MAX_TRIALS}" -lt 1 ] ; then
   eval_gettext >&2 "ERROR: Invalid maximum trials \${MAX_TRIALS}!"
   echo >&2
   exit 1
fi
delayValue="$2"
if [[ ! "${delayValue}" =~ ^([0-9]+|[0-9]*\.[0-9]+|[0-9]+\.[0-9]*)$ ]] ; then
   eval_gettext >&2 "ERROR: Invalid delay value \${delayValue}!"
   echo >&2
   exit 1
fi
if [ "${DETERMINISTIC}" -eq 0 ] && ! command -v random-sleep >/dev/null ; then
   gettext >&2 "ERROR: Cannot find random-sleep in the search path!"
   echo >&2
   exit 1
fi
MAX_DELAY="${delayValue}"
shift 2


# ====== Ensure that min delay < max delay ==================================
read -r minDelay maxDelay <<<"$(awk \
   -v minDelayArgument="${MIN_DELAY}" \
   -v maxDelayArgument="${MAX_DELAY}" '\
function min(a, b) { return (a < b ? a : b); }
function max(a, b) { return (a > b ? a : b); }
BEGIN {
   minDelay    = min(minDelayArgument, maxDelayArgument);
   maxDelay    = max(minDelayArgument, maxDelayArgument);
   printf("%g %g\n", minDelay, maxDelay);
}
'
)"


# ====== Run loop ===========================================================
trial=0
while true ; do
   # ====== Start next trial ================================================
   trial=$(( trial+1 ))
   if [ "${VERBOSE}" -eq 1 ] ; then
      echo -e "\x1b[34m$(date +%FT%H:%M:%S): $(eval_gettext "Trial \${trial}/\${MAX_TRIALS}: \x1b[37m$*")\x1b[0m"
   fi

   # ====== Run the command =================================================
   "$@" && exit 0 || exitStatus=$?

   # ====== Check whether trial limit has been reached ======================
   if [ ${trial} -ge "${MAX_TRIALS}" ] ; then
      if [ "${VERBOSE}" -eq 1 ] ; then
         echo -e "\x1b[34m$(date +%FT%H:%M:%S): $(eval_gettext "Tried \${MAX_TRIALS} times -> giving up now!")\x1b[0m"
      fi
      exit "${exitStatus}"
   fi

   # ====== Increase delay for next trial ===================================
   if [ ${trial} -gt 1 ] ; then
      read -r minDelay maxDelay <<<"$(awk \
         -v minDelayArgument="${minDelay}" \
         -v maxDelayArgument="${maxDelay}" \
         -v additiveIncrease="${ADDITIVE_INCREASE}" \
         -v multiplicativeIncrease="${MULTIPLICATIVE_INCREASE}" \
         -v minDelayBoundary="${MIN_DELAY}" \
         -v maxDelayBoundary="${TRUNCATE_DELAY}" '\
function min(a, b) { return (a < b ? a : b); }
function max(a, b) { return (a > b ? a : b); }
BEGIN {
   minDelay    = min(minDelayArgument, maxDelayArgument);
   maxDelay    = max(minDelayArgument, maxDelayArgument);

   newMinDelay = max(min(minDelay*multiplicativeIncrease + additiveIncrease, maxDelayBoundary), minDelayBoundary);
   newMaxDelay = max(min(maxDelay*multiplicativeIncrease + additiveIncrease, maxDelayBoundary), minDelayBoundary);
   printf("%g %g\n", min(newMinDelay, newMaxDelay),max(newMinDelay, newMaxDelay));
}
'
)"
   fi

   # ====== Wait a random time span =========================================
   if [ "${DETERMINISTIC}" -eq 0 ] ; then
      if [ "${VERBOSE}" -eq 1 ] ; then
         echo -e "\x1b[34m$(date +%FT%H:%M:%S): $(eval_gettext "Trial \${trial}/\${MAX_TRIALS} failed (exit code \${exitStatus}) -> waiting random time from [\${minDelay}, \${maxDelay}] s ...")\x1b[0m"
         random-sleep -w "${minDelay}" "${maxDelay}"
      else
         random-sleep "${minDelay}" "${maxDelay}"
      fi
   else
      if [ "${VERBOSE}" -eq 1 ] ; then
         echo -e "\x1b[34m$(date +%FT%H:%M:%S): $(eval_gettext "Trial \${trial}/\${MAX_TRIALS} failed -> waiting for \${maxDelay} s ...")\x1b[0m"
      fi
      sleep "${maxDelay}"
   fi
done
